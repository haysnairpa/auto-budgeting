# Copy this file to .env and fill in the values

# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Must match what you registered as "Authorized redirect URI" in Google Cloud Console
# Local dev:  http://localhost:8000/auth/callback
# Production: https://your-app.railway.app/auth/callback
REDIRECT_URI=http://localhost:8000/auth/callback

# Directory for SQLite DB and OAuth token file
# Local:    ./data
# Railway:  /data  (set this in Railway env vars + add a volume mounted at /data)
DATA_DIR=./data
