# Copy this file to .env and fill in the values

# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Must match "Authorized redirect URI" in Google Cloud Console
# Local dev:  http://localhost:8000/auth/callback
# Render:     https://autobudget.onrender.com/auth/callback
REDIRECT_URI=http://localhost:8000/auth/callback

# From Supabase → Project Settings → Database → Connection String (URI)
# Use the "Transaction pooler" URL for best compatibility
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# Where to store the Gmail OAuth token file
# Local: ./data    |   Render: /tmp  (token will reset on restart — re-auth needed rarely)
DATA_DIR=./data
